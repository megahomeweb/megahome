rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user is admin.
    // SECURITY MODEL: admin is identified by EMAIL, not by the role field
    // in the Firestore user doc. This means even if someone tampers with
    // their own user doc to set role='admin', they don't gain admin
    // access — they don't own the hardcoded admin email. The single
    // admin identity is wired both here and in lib/admin-config.ts; keep
    // them in sync if you ever rotate.
    function isAdmin() {
      return isAuth() &&
        request.auth.token.email == 'hayatabdulloh@gmail.com';
    }

    // Helper: Check if user is staff (admin OR manager). Manager remains
    // a Firestore-doc-based role for now since there's no separate
    // hardcoded list — managers get cross-customer read access to the
    // user collection but no admin privileges (write to products,
    // categories, etc. require isAdmin).
    function isStaff() {
      return isAdmin() || (
        isAuth() &&
        get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'manager'
      );
    }

    // Helper: Check if user owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles
    // - Users self-create on signup
    // - Admins can create customer profiles from POS / admin panel
    //   (POS-created customers have no Firebase Auth user; admin writes
    //   the doc with `role: "user"` and `createdViaPos: true`)
    // - READ access: previously `allow read: if isAuth()` — any logged-in
    //   customer could enumerate every other customer's phone/email (PII
    //   leak). Now restricted to OWNER or STAFF (admin/manager).
    // User profile updates: owners can update their OWN profile, but
    // CANNOT change role / phone / email / uid. Without this lock, a
    // signed-in customer could `updateDoc(myDoc, { role: 'admin' })` and
    // then call /api/orders/create with `targetUserUid` to place orders
    // attributed to other customers, or call /api/delete-user to wipe
    // the user collection. Two server routes (orders/create:134,
    // customers/create:54, delete-user) currently read role from this
    // doc as the gate — locking the field down here removes the
    // self-promotion vector without needing to ship every server fix
    // simultaneously.
    //
    // Phone is also locked: nasiya entries and Telegram ref handling
    // dedupe on phone, so a customer rewriting their own phone could
    // hijack another customer's debt or referral chain.
    match /user/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId)
        || (isAdmin() && request.resource.data.role == 'user');
      allow update: if (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.phone == resource.data.phone
          && request.resource.data.email == resource.data.email
          && request.resource.data.uid == resource.data.uid)
        || isAdmin();
      allow delete: if isAdmin();
    }

    // Products — public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — users can read own, admin can read/write all.
    // Create is SERVER-ONLY: the /api/orders/create route uses the Firebase
    // Admin SDK (which bypasses rules) to atomically validate stock + prices
    // against the products collection before writing the order. Allowing
    // client-side create would let a user tamper with `totalPrice` or the
    // embedded `basketItems[*].price` in DevTools.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Stock receipts — admin only
    match /stockReceipts/{receiptId} {
      allow read, write: if isAdmin();
    }

    // Stock movements — admin only
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // Invoices — admin only
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // Nasiya (customer credit) ledger — created server-side by /api/orders/create
    // when a sale includes a credit portion. Admins can read all and update
    // (mark paid). Customers can read their own entries by uid.
    match /nasiya/{nasiyaId} {
      allow read: if isAdmin() || (isAuth() && resource.data.customerUid == request.auth.uid);
      allow create: if false; // server-only
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Telegram webhook idempotency dedup — pure server-side via Admin SDK.
    // No client should ever read/write this collection.
    match /processedUpdates/{updateId} {
      allow read, write: if false;
    }

    // Order/POS idempotency keys — server-only via Admin SDK. Prevents
    // double-create on retry.
    match /idempotencyKeys/{key} {
      allow read, write: if false;
    }

    // Telegram pending referrals — server-only stash for /start ref payloads
    // before customer shares phone. Admin SDK creates + cleans up.
    match /telegramPendingRefs/{chatId} {
      allow read, write: if false;
    }

    // Promo codes — admin manages from /admin/promo, server applies at order
    // commit. Clients shouldn't write (would let users mint codes for self).
    // Read locked to admin: previously `allow read: if isAuth()` let any
    // signed-in customer enumerate every code, value, expiry, and the
    // `usedBy[uid]` map (PII — tells you which other customers redeemed
    // what). Customers redeem by submitting the code STRING to
    // /api/orders/create which validates server-side; they never need
    // direct read access.
    match /promoCodes/{codeId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Telegram users — admin read/write, users can read own
    match /telegramUsers/{telegramUserId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow write: if isAdmin() || (isAuth() && request.resource.data.userUid == request.auth.uid);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
