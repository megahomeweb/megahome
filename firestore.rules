rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: Check if user is admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Check if user owns the document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // User profiles
    // - Users self-create on signup
    // - Admins can create customer profiles from POS / admin panel
    //   (POS-created customers have no Firebase Auth user; admin writes
    //   the doc with `role: "user"` and `createdViaPos: true`)
    match /user/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        || (isAdmin() && request.resource.data.role == 'user');
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Products — public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — users can read own, admin can read/write all.
    // Create is SERVER-ONLY: the /api/orders/create route uses the Firebase
    // Admin SDK (which bypasses rules) to atomically validate stock + prices
    // against the products collection before writing the order. Allowing
    // client-side create would let a user tamper with `totalPrice` or the
    // embedded `basketItems[*].price` in DevTools.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Stock receipts — admin only
    match /stockReceipts/{receiptId} {
      allow read, write: if isAdmin();
    }

    // Stock movements — admin only
    match /stockMovements/{movementId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // Invoices — admin only
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // Nasiya (customer credit) ledger — created server-side by /api/orders/create
    // when a sale includes a credit portion. Admins can read all and update
    // (mark paid). Customers can read their own entries by uid.
    match /nasiya/{nasiyaId} {
      allow read: if isAdmin() || (isAuth() && resource.data.customerUid == request.auth.uid);
      allow create: if false; // server-only
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Telegram users — admin read/write, users can read own
    match /telegramUsers/{telegramUserId} {
      allow read: if isAdmin() || (isAuth() && resource.data.userUid == request.auth.uid);
      allow write: if isAdmin() || (isAuth() && request.resource.data.userUid == request.auth.uid);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
